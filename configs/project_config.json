        "num_experts": 7,
        "expert_domains": [
            "algebraic_geometry",
            "discrete_math",
            "number_theory",
            "analysis",
            "algebra",
            "geometry_topology",
            "probability_statistics"
        ],
        "training": {
            "lora_rank": 64,
            "lora_alpha": 128,
            "learning_rate": 1e-4,
            "batch_size_per_gpu": 4,
            "gradient_accumulation_steps": 8,
            "num_epochs": 3,
            "warmup_ratio": 0.03,
            "max_seq_length": 4096,
            "checkpoint_interval_steps": 50,
            "resume_from_checkpoint": true
        }
    },

    "pipeline": {
        "stratified_sample_size_per_cat": 100,
        "theorem_extraction_batch_size": 50,
        "conjecture_generation_temperature": 0.8,
        "lean_verification_timeout_seconds": 60,
        "max_proof_search_depth": 10
