    "gpu_resources": {
        "dgx_a100": {
            "gpus": 8,
            "gpu_memory_gb": 80,
            "total_memory_gb": 640,
            "available_hours": 72
        },
        "dgx_h100": {
            "gpus": 8,
            "gpu_memory_gb": 80,
            "total_memory_gb": 640,
            "available_hours": 72
        }
    },

    "moe_config": {
        "approach": "domain_specialized_lora_moe",
        "base_model_candidates": [
            "deepseek-ai/deepseek-math-7b-base",
            "deepseek-ai/deepseek-math-7b-instruct",
            "internlm/internlm2-math-plus-7b",
            "EleutherAI/llemma_7b",
            "Qwen/Qwen2.5-Math-7B",
            "mistralai/Mixtral-8x7B-v0.1"
